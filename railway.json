{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "BUILDPACKS",
    "buildpacks": [
      "heroku/php",
      "heroku/nodejs"
    ]
  },
  "deploy": {
    "startCommand": "cd backend && php artisan serve --host=0.0.0.0 --port=$PORT",
    "restartPolicyMaxRetries": 5,
    "restartPolicyWindowSeconds": 600
  }
}
